 <% layout('/layouts/boilerplate.ejs') -%>
 <style>
    .filters{
        margin-left: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
        overflow-x: auto;
        white-space: nowrap;
        scrollbar-width: none;
    }
    .filter{
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity:0.7;
        text-decoration: none;
        color: black;  
    }
    .filter i{
        font-size: 0.8rem;
    }
     .filter:hover{
        opacity:1;
        cursor:pointer;
    }
 </style>
<body>
    <div class="container-fluid pt-3 mb-4">
        <div class="filters d-flex gap-3">
            <a class="filter" href="/listings">
                <i class="fa-solid fa-fire"></i>
                <p>treding</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-solid fa-cow"></i>
                <p>farms</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-solid fa-bed"></i>
                <p>rooms</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-solid fa-landmark"></i>
                <p>iconic cities</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-solid fa-mountain-city"></i>
                <p>moutain</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-solid fa-person-swimming"></i>
                <p>awazing pool</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-brands fa-fort-awesome"></i>
                <p>castles</p>
            </a>
            <a class="filter" href="/listings">
                <i class="fa-regular fa-snowflake"></i>
                <p>arctic</p>
            </a>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 cards-sec">
        <%for(listing of listings){%>
        <a href="/listings/<%=listing._id%>" style="text-decoration: none;">
            <div class="card home-card ListCard">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="LISTING">
                <div class="card-body col">
                    <p class="card-text">
                        <b><%=listing.title%></b> <br>
                        &#8377; <%=listing.price.toLocaleString("en-IN")%>/night
                    </p>
                </div>
            </div>
        </a>
        <%}%>
    </div>
</body>