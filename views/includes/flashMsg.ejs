<%if(success && success.length){%>
    <div class="row">
        <div class="alert alert-success col-6 offset-3 py-1 alert-dismissible " role="alert">
            <%=success%>
            <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<%}%>

<%if(error && error.length){%>
    <div class="row">
        <div class="alert alert-danger col-6 offset-3 py-1 text-center alert-dismissible" role="alert">
            <%=error%>
            <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<%}%>

    
