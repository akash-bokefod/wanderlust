<style>
    .search-btn{
        background-color: #fe424d;
        color: #fff;
        padding: 0 1rem;
        border-radius: 20px;
    }
    .search-btn:hover{
        background-color: #fe424d;
        color: #fff;
    }
    .search-btn i{
        display: inline;
        margin-right: 8px;
    }
    .search-input{
        border-radius: 20px;
        padding: 0.7rem 1.5rem;
        font-size: 0.8rem;
    }
</style>
<body>
    <nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href=""><i class="fa-regular fa-compass"></i></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
            </div>
            <div class="navbar-nav ms-auto">
                <form class="d-flex" action="/listings" method="get">
                    <input 
                        class="form-control me-2 search-input" type="search" 
                        placeholder="Search destination" 
                        aria-label="Search" 
                        name="search" 
                        value="<%=search ? search : ''%>"
                    />
                    <button class="btn btn-outline-success search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
                </form>
            </div>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/listings/new">Airhub your home</a>
                <% if(!currUser){ %>
                    <a class="nav-link" href="/signup">Signup</a>
                    <a class="nav-link" href="/login">Login</a>
                <% } %>
                <% if(currUser){ %>
                    <a class="nav-link" href="/logout">Logout</a>
                <% } %>
            </div>
            </div>
        </div>
    </nav>
</body>